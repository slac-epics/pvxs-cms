# EPICS Base
BASE_DIRNAME=base
BASE_REPONAME=epics-base-tls
BASE_REPOOWNER=slac-epics
BASE=7.0
BASE_VARNAME=EPICS_BASE
BASE_RECURSIVE=yes
BASE_HOOK=.ci-local/propagate_flags.sh

# PVXS - Secure PVAccess library (built as dependency using system/brew/vcpkg libevent)
MODULES=pvxs
PVXS_DIRNAME=pvxs
PVXS_REPONAME=pvxs-tls
PVXS_REPOOWNER=slac-epics
PVXS=dev
PVXS_VARNAME=PVXS
PVXS_RECURSIVE=yes
