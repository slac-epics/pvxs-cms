# EPICS Base
BASE_DIRNAME=base
BASE_REPONAME=epics-base-tls
BASE_REPOOWNER=slac-epics
BASE=7.0
BASE_VARNAME=EPICS_BASE
BASE_RECURSIVE=no

# PVXS - Secure PVAccess library
MODULES=pvxs
PVXS_DIRNAME=pvxs
PVXS_REPONAME=pvxs-tls
PVXS_REPOOWNER=slac-epics
PVXS=pvxs-tls
PVXS_VARNAME=PVXS
# Use PVXS's bundled libevent submodule
PVXS_RECURSIVE=yes
