# EPICS Base - for cross compilation targets (RTEMS, mingw)
BASE_DIRNAME=base
BASE_REPONAME=epics-base-tls
BASE_REPOOWNER=slac-epics
BASE=7.0
BASE_VARNAME=EPICS_BASE
BASE_RECURSIVE=no

PVXS_DIRNAME=pvxs
PVXS_REPONAME=pvxs-tls
PVXS_REPOOWNER=slac-epics
PVXS=tls
PVXS_VARNAME=PVXS
PVXS_RECURSIVE=yes

# Hook to build libevent before building pvxs-tls for cross targets
PVXS_HOOK=.ci-local/pvxs-cross-hook.py